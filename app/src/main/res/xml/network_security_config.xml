<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Dies ist die korrekte und sichere Konfiguration.
        - HTTP (Cleartext) wird global verboten.
        - Die App vertraut den offiziellen System-Zertifikaten SOWIE den vom Benutzer
          manuell installierten CA-Zertifikaten. Das ist die entscheidende Regel, 
          damit die HTTPS-Synchronisation funktioniert.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
