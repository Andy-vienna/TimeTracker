<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config>
        <!-- Domain ist die IP deines Servers -->
        <domain includeSubdomains="false">192.168.1.60</domain>
        <!-- Verweise auf das Zertifikat, das du in res/raw kopiert hast -->
        <trust-anchors>
            <certificates src="@raw/server"/>
        </trust-anchors>
    </domain-config>
</network-security-config>

    